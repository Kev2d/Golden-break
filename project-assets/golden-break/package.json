{
  "name": "keweb",
  "version": "1.0.0",
  "scripts": {
    "build": "npx babel assets/js --out-file dist/main.min.js && npm run scss",
    "watch:js": "webpack --watch",
    "watch:css": "sass --watch assets/scss/main.scss:assets/dist/css/main.min.css --style=compressed --no-source-map",
    "watch": "concurrently \"php functions/classes/generate-scss.php\" \"npm run watch:js\" \"npm run watch:css\"",
    "scss": "sass --watch assets/scss/style.scss:dist/style.min.css --style compressed --no-source-map",
    "sync": "browser-sync start --proxy \"localhost:8000\" --files \"**/*\""
  },
  "type": "commonjs",
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@babel/cli": "^7.19.3",
    "@fullhuman/postcss-purgecss": "^7.0.2",
    "autoprefixer": "^10.4.20",
    "babel-preset-minify": "^0.5.2",
    "compression-webpack-plugin": "^11.1.0",
    "concurrently": "^8.0.1",
    "css-loader": "^6.11.0",
    "css-minimizer-webpack-plugin": "^5.0.1",
    "fork-ts-checker-webpack-plugin": "^8.0.0",
    "fs": "^0.0.1-security",
    "mini-css-extract-plugin": "^2.9.2",
    "nodemon": "^3.1.4",
    "postcss": "^8.4.49",
    "postcss-loader": "^8.1.1",
    "purgecss": "^7.0.2",
    "purgecss-webpack-plugin": "^7.0.2",
    "purgecss-with-wordpress": "^7.0.2",
    "sass": "^1.82.0",
    "sass-loader": "^13.3.3",
    "style-loader": "^3.3.2",
    "terser-webpack-plugin": "^5.3.10",
    "ts-loader": "^9.4.4",
    "typescript": "^5.1.6",
    "watch": "^0.13.0",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4"
  },
  "main": "index.js",
  "description": "This is a base template for web development projects. It includes a set of folders and files that are commonly used as a starting point.",
  "dependencies": {
    "swiper": "^11.1.15"
  }
}
